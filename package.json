{
  "name": "@zivego/n8n-nodes-dfir-iris",
  "version": "3.0.0",
  "description": "n8n node for DFIR IRIS IRP",
  "license": "MIT",
  "homepage": "https://github.com/zivego/iris-n8n-fork",
  "keywords": [
    "n8n-community-node-package",
    "dfir-iris",
    "iris",
    "zivego"
  ],
  "author": {
    "name": "zivego",
    "email": "266826730+zivego@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zivego/iris-n8n-fork.git"
  },
  "bugs": {
    "url": "https://github.com/zivego/iris-n8n-fork/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/clean-build-output.mjs && node scripts/check-credential-password-fields.mjs && node scripts/check-api-coverage.mjs && n8n-node build && node scripts/prune-package-dist.mjs",
    "build:watch": "tsc --watch",
    "check:api-coverage": "node scripts/check-api-coverage.mjs",
    "check:credentials-schema": "node scripts/check-credential-password-fields.mjs",
    "clean": "node scripts/clean-build-output.mjs",
    "dev": "n8n-node dev",
    "lint": "eslint credentials nodes scripts --ext .ts,.js,.mjs",
    "lint:fix": "eslint credentials nodes scripts --ext .ts,.js,.mjs --fix",
    "pack:tarball": "pnpm run build && pnpm pack --pack-destination artifacts",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm run release:publish",
    "release:check": "pnpm run lint && pnpm test && pnpm run build && pnpm pack --pack-destination artifacts && pnpm publish --dry-run --access public --no-git-checks",
    "release:publish": "pnpm run release:check && pnpm publish --access public --no-git-checks",
    "test": "vitest run tests/unit tests/contract tests/integration",
    "test:coverage": "vitest run tests/unit tests/contract tests/integration --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:live": "vitest run tests/e2e/live-lab.test.ts",
    "test:e2e:regression": "vitest run tests/e2e/n8n-regression.test.ts",
    "test:integration": "vitest run tests/contract tests/integration",
    "test:unit": "vitest run tests/unit"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/DfirIrisApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DfirIris/DfirIris.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "0.18.0",
    "@types/node": "^20.19.30",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "9.32.0",
    "n8n-workflow": "2.4.3",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "n8n-workflow": "2.4.3"
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c",
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "@types/node": "20.19.30",
      "form-data": "4.0.4",
      "glob@10": "10.5.0",
      "glob@7": "7.2.3",
      "lodash-es": "4.17.23",
      "lodash": ">=4.17.23",
      "undici@6": "^6.23.0",
      "undici@7": "^7.18.2",
      "js-yaml": "4.1.1"
    }
  }
}
